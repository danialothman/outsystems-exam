run = "pip install -r requirements.txt && python app.py"
language = "python3"
modules = ["python-3.11"]

[deployment]
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "app:app"]
deploymentTarget = "vm"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[objectStorage]
defaultBucketID = "replit-objstore-8ea03f17-91f2-4581-adfd-e0be2525dd35"
